# --- Civo -------------------------------------------------------------------
civo_api_token     = "REPLACE_ME"         # https://dashboard.civo.com/security
civo_region        = "LON1"
civo_instance_size = "g3.small"           # bump to "g3.medium" if the guardrail runs hot
civo_disk_image    = "ubuntu-noble"
hostname           = "defenseclaw"

# --- SSH access -------------------------------------------------------------
# Access is via Civo's auto-generated password for the default "civo" user.
# After apply, run:  terraform output -raw ssh_password
#
# Optional: source-IP lock for port 22. Defaults to ["0.0.0.0/0"] (open).
# Strongly recommended when using password auth — otherwise the internet can
# brute-force the password.
# ssh_allowed_cidr = ["123.123.123.5/32"]

# --- Relax.ai (OpenClaw model backend) --------------------------------------
relax_api_key = "REPLACE_ME"
relax_model = "Kimi-K25"

# --- Slack (optional) -------------------------------------------------------
# Leave empty to skip Slack integration.
slack_bot_token = ""
slack_app_token = ""
